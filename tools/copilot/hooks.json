{
  "hooks": [
    {
      "event": "preToolUse",
      "filter": {
        "toolNames": ["edit", "create"]
      },
      "command": "PATH=$HOME/.local/bin:$PATH neph integration hook copilot"
    },
    {
      "event": "postToolUse",
      "filter": {
        "toolNames": ["edit", "create"]
      },
      "command": "PATH=$HOME/.local/bin:$PATH neph integration hook copilot"
    },
    {
      "event": "sessionStart",
      "command": "PATH=$HOME/.local/bin:$PATH neph integration hook copilot"
    },
    {
      "event": "sessionEnd",
      "command": "PATH=$HOME/.local/bin:$PATH neph integration hook copilot"
    }
  ]
}
