{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "name": "neph-lifecycle",
            "command": "neph integration hook gemini",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "name": "neph-lifecycle",
            "command": "neph integration hook gemini",
            "timeout": 10000
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "name": "neph-lifecycle",
            "command": "neph integration hook gemini",
            "timeout": 10000
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "name": "neph-lifecycle",
            "command": "neph integration hook gemini",
            "timeout": 10000
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "write_file|edit_file|replace",
        "hooks": [
          {
            "type": "command",
            "name": "neph-review",
            "command": "neph integration hook gemini",
            "timeout": 600000
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "write_file|edit_file|replace",
        "hooks": [
          {
            "type": "command",
            "name": "neph-checktime",
            "command": "neph integration hook gemini",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
