{
  "version": "neph-rpc/v1",
  "methods": {
    "review.open": {
      "params": ["request_id", "path", "content"],
      "optional_params": ["channel_id", "result_path", "agent", "mode"],
      "async": true
    },
    "status.set": {
      "params": ["name", "value"],
      "async": false
    },
    "status.unset": {
      "params": ["name"],
      "async": false
    },
    "status.get": {
      "params": ["name"],
      "async": false
    },
    "buffers.check": {
      "params": [],
      "async": false
    },
    "tab.close": {
      "params": [],
      "async": false
    },
    "ui.select": {
      "params": ["request_id", "channel_id", "title", "options"],
      "async": true
    },
    "ui.input": {
      "params": ["request_id", "channel_id", "title", "default"],
      "async": true
    },
    "ui.notify": {
      "params": ["message", "level"],
      "async": false
    },
    "tools.status": {
      "params": [],
      "async": false
    },
    "tools.install": {
      "params": ["name"],
      "async": false
    },
    "tools.install_all": {
      "params": [],
      "async": false
    },
    "tools.uninstall": {
      "params": ["name"],
      "async": false
    },
    "tools.preview": {
      "params": [],
      "async": false
    },
    "review.status": {
      "params": [],
      "async": false
    },
    "review.accept": {
      "params": [],
      "optional_params": ["idx"],
      "async": false
    },
    "review.reject": {
      "params": [],
      "optional_params": ["idx", "reason"],
      "async": false
    },
    "review.accept_all": {
      "params": [],
      "async": false
    },
    "review.reject_all": {
      "params": [],
      "optional_params": ["reason"],
      "async": false
    },
    "review.submit": {
      "params": [],
      "async": false
    },
    "review.next": {
      "params": [],
      "async": false
    }
  }
}
