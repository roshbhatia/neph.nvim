{
  "version": "neph-rpc/v1",
  "methods": {
    "review.open": {
      "params": ["request_id", "result_path", "channel_id", "path", "content"],
      "async": true
    },
    "status.set": {
      "params": ["name", "value"],
      "async": false
    },
    "status.unset": {
      "params": ["name"],
      "async": false
    },
    "status.get": {
      "params": ["name"],
      "async": false
    },
    "buffers.check": {
      "params": [],
      "async": false
    },
    "tab.close": {
      "params": [],
      "async": false
    },
    "ui.select": {
      "params": ["request_id", "channel_id", "title", "options"],
      "async": true
    },
    "ui.input": {
      "params": ["request_id", "channel_id", "title", "default"],
      "async": true
    },
    "ui.notify": {
      "params": ["message", "level"],
      "async": false
    }
  }
}
